# SARA Backend 환경 설정

# GenAI Gateway
GENAI_API_URL=https://genai-sharedservice-americas.pwcinternal.com
GENAI_API_KEY=your-api-key-here
GENAI_MODEL=bedrock.anthropic.claude-sonnet-4-6

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# File limits
MAX_FILE_SIZE_MB=50
JOB_RETENTION_HOURS=24
